# MW-POS Environment Variables
# Copy to .env.local and fill in values

# === Firebase ===
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# === Firebase Admin (Server-side only) ===
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Emergency login fallback. Keep disabled unless explicitly required.
# This value is server-only and must be exactly six digits.
ENABLE_MASTER_OTP=false
LOGIN_MASTER_OTP=

# Phone number used by `npm run seed` for the first superadmin (E.164 format)
SEED_SUPERADMIN_PHONE=+919876543210
# Public copy used only to reveal the superadmin password field on the login screen
NEXT_PUBLIC_SUPERADMIN_PHONE=+919876543210
# Server-only superadmin password. Use a strong, unique value.
SUPERADMIN_PASSWORD=

# === Session ===
SESSION_SECRET=generate-a-random-64-char-string-here
# === Email Notifications (Gmail SMTP) ===
# For Gmail: use an App Password (not your regular password)
# 1. Enable 2FA on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an App Password for "Mail"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="MW-POS <your-email@gmail.com>"

# === App ===
NEXT_PUBLIC_APP_NAME=MW-POS
NEXT_PUBLIC_APP_URL=http://localhost:3000
